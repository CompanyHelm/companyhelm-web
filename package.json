{
  "name": "CompanyHelm",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "files": [
    "public/**",
    "schema/**",
    "src/**",
    "index.html",
    "vite.config.js"
  ],
  "scripts": {
    "config:generate": "node scripts/config/generate-runtime-config.js",
    "dev": "npm run config:generate -- --environment local && vite dev",
    "build": "npm run config:generate -- --environment prod && vite build",
    "preview": "npm run config:generate -- --environment prod && vite preview",
    "test": "node --test tests/**/*.test.js"
  },
  "dependencies": {
    "@companyhelm/protos": "^0.4.0",
    "@supabase/supabase-js": "^2.98.0",
    "@xyflow/react": "^12.10.1",
    "elkjs": "^0.11.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^10.1.0",
    "react-relay": "^20.1.1",
    "relay-runtime": "^20.1.1",
    "remark-gfm": "^4.0.1",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "vite": "^5.4.10",
    "yaml": "^2.8.1"
  }
}
