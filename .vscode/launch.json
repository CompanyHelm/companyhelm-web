{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run UI locally (Generate Config + Vite + Brave)",
      "type": "pwa-node",
      "request": "launch",
      "cwd": "${workspaceFolder}",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "console": "integratedTerminal",
      "serverReadyAction": {
        "pattern": "Local:\\s+(https?://\\S+)",
        "uriFormat": "%s",
        "action": "startDebugging",
        "name": "Debug UI in Brave"
      }
    },
    {
      "name": "Debug UI in Brave",
      "type": "pwa-chrome",
      "request": "launch",
      "url": "http://localhost:4173",
      "webRoot": "${workspaceFolder}",
      "runtimeExecutable": "/Applications/Brave Browser.app/Contents/MacOS/Brave Browser"
    }
  ]
}
